DATABASE_URL="postgresql://tarasense:change_this_password@127.0.0.1:5432/tarasense?schema=public"
NEXTAUTH_URL="https://your-domain.com"
ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="change-this-admin-password"

# Optional: external API base URL (for separate backend deployment).
# Leave empty to use same-origin Next.js routes (/api/*), recommended for single-app deployment.
NEXT_PUBLIC_API_URL=""

# Optional: enables AI recommendation text in study analysis pages.
OPENAI_API_KEY=""

# Optional runtime settings
NODE_ENV="production"
PORT="3000"

# Reminder job protection and timezone
CRON_SECRET="replace-with-long-random-secret"
REMINDER_TIMEZONE="Asia/Manila"
